{
  "manifest_version": 3,
  "name": "Obsi Redbook Clipper",
  "description": "Clip Xiaohongshu posts and public WeChat articles into Obsidian-friendly Markdown.",
  "version": "0.1.0",
  "action": {
    "default_title": "Obsi Redbook Clipper",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "permissions": [
    "activeTab",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "https://www.xiaohongshu.com/*",
    "https://xhslink.com/*",
    "https://mp.weixin.qq.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.xiaohongshu.com/*",
        "https://xhslink.com/*",
        "https://mp.weixin.qq.com/*"
      ],
      "js": [
        "shared.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
