{
  "manifest_version": 3,
  "name": "Obsi Redbook Clipper",
  "short_name": "Obsi Redbook",
  "description": "Clip Xiaohongshu posts and public WeChat articles into Obsidian-friendly Markdown.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Obsi Redbook Clipper",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "options_page": "options.html",
  "permissions": [
    "activeTab",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "https://www.xiaohongshu.com/*",
    "https://xhslink.com/*",
    "https://mp.weixin.qq.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.xiaohongshu.com/*",
        "https://xhslink.com/*",
        "https://mp.weixin.qq.com/*"
      ],
      "js": [
        "shared.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "homepage_url": "https://github.com/xuezixuan26-design/obsi-redbook"
}
